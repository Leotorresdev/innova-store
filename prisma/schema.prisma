datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ProductType {
  PRODUCT
  PRESALE
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  isNew       Boolean     @default(true)
  imageUrl    String
  type        ProductType
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
